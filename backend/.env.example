# Backend Environment
NODE_ENV=development
PORT=8080

# MongoDB
MONGODB_URL=mongodb://root:example@localhost:27017/trading?authSource=admin
MONGODB_DB_NAME=trading

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-prod-please-use-a-long-random-string
JWT_EXPIRES=24h

# CORS
FRONTEND_URL=http://localhost:5173

# WebSocket
ALLOW_ANON_WS=true

# Market simulator
TICK_INTERVAL_MS=1000
