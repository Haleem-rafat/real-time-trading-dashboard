# Production env vars for Vercel deployment.
# Copy this to `.env.production` and fill in your Fly app URL,
# OR set these in the Vercel dashboard → Settings → Environment Variables.
#
# Both URLs point at the same Fly app (the backend handles REST + WS on
# the same port).

VITE_API_URL=https://trading-backend.fly.dev/api/v1
VITE_SOCKET_URL=https://trading-backend.fly.dev
